{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Zeru",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.zeru",
                    "match": "\\b(if|else|while|for|in|break|continue|return|match|default)\\b"
                },
                {
                    "name": "keyword.declaration.zeru",
                    "match": "\\b(fn|var|const|struct|enum|trait|import|as|asm|volatile)\\b"
                },
                {
                    "name": "constant.language.zeru",
                    "match": "\\b(true|false|None|self)\\b"
                },
                {
                    "name": "storage.type.zeru",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|usize|f32|f64|bool|str|Array|Vec)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.zeru",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.zeru",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.zeru",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.zeru",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.zeru",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.zeru",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.zeru",
                    "match": "\\b0b[01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.zeru",
                    "match": "\\b0o[0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.zeru",
                    "match": "\\b\\d+\\.\\d*\\b"
                },
                {
                    "name": "constant.numeric.integer.zeru",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.zeru",
                    "match": "([-+*/%&|^<>!=]=*|&&|\\|\\||=>|::)"
                }
            ]
        }
    ],
    "scopeName": "source.zeru"
}
